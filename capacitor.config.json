{
  "appId": "ar.fausto.datarg",
  "appName": "DatArg",
  "webDir": "dist",
  "backgroundColor": "#06101f",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SystemBars": {
      "insetsHandling": "css",
      "style": "DARK",
      "hidden": false
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1600,
      "backgroundColor": "#06101fff",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#06101f",
      "overlaysWebView": false
    },
    "FirebaseMessaging": {
      "presentationOptions": ["alert", "badge", "sound"]
    }
  },
  "experimental": {
    "ios": {
      "spm": {
        "packageOptions": {
          "@capacitor-firebase/messaging": {
            "symlink": true
          }
        }
      }
    }
  }
}
