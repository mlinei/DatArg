{
  "name": "datarg",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync-data": "node web/scripts/sync-data.mjs",
    "dev": "npm run sync-data && vite --host 0.0.0.0",
    "build": "npm run sync-data && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "native:sync": "npm run build && cap sync",
    "native:assets": "capacitor-assets generate --ios --android --iconBackgroundColor '#06101f' --iconBackgroundColorDark '#06101f' --splashBackgroundColor '#06101f' --splashBackgroundColorDark '#06101f'",
    "native:ios": "npm run native:sync && cap open ios",
    "native:android": "npm run native:sync && cap open android",
    "native:doctor": "cap doctor"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.2",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3"
  }
}
